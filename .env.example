# ============================================================================
# Locavo — variables de entorno (EJEMPLO — nunca credenciales reales)
#
# Copia este archivo a `.env` y llena los valores de TU proyecto Supabase
# cuando exista uno (V4B+). `.env` está ignorado por Git.
#
# SOLO variables públicas de cliente (prefijo EXPO_PUBLIC_). La publishable
# key está diseñada para ser embebida en el cliente y queda limitada por
# Row Level Security en la base.
#
# JAMÁS pongas aquí ni en el cliente:
#   - service_role / secret keys
#   - contraseñas de base de datos
#   - access tokens personales de Supabase
#   - tokens de INEGI/DENUE
# Esos valores viven únicamente en backend/CI (fuera de este repositorio).
# ============================================================================

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
