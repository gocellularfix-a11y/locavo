{
  "name": "locavo",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "db:types": "supabase gen types typescript --local > src/data/supabase/database.types.ts",
    "denue:extract": "node scripts/denue/build-pilot-extract.mjs",
    "denue:import": "tsx scripts/denue/import-pilot.ts",
    "denue:prepare:culiacan": "tsx scripts/denue/prepare-culiacan.ts",
    "denue:manifest": "tsx scripts/denue/build-archive-manifest.ts",
    "citypack:build:culiacan": "tsx scripts/citypack/build-culiacan.ts",
    "citypack:stage": "tsx scripts/citypack/stage.ts",
    "citypack:bundle": "tsx scripts/citypack/build-bundled.ts",
    "osm:snapshot:verify": "tsx scripts/osm/verify-snapshot.ts",
    "build:web": "npm run citypack:bundle && expo export --platform web",
    "acceptance:web": "npm run build:web && npx serve dist -l 4173",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build:web"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.7",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-localization": "~57.0.1",
    "expo-location": "~57.0.5",
    "expo-router": "~57.0.7",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "leaflet": "^1.9.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^4.0.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.5",
    "eslint-config-expo": "^57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.2",
    "pg": "^8.22.0",
    "supabase": "^2.109.1",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  }
}
